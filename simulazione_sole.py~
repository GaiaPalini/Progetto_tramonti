"""
SIMULAZIONE DEL TRAMONTO SOLARE

Simula la distribuzione spettrale dei fotoni solari dopo l'attraversamento
dell'atmosfera terrestre a diversi angoli zenitali.

Produce due grafici:
    1. Distribuzione spettrale dei fotoni a theta=0 (zenit) e theta=pi/2
       (orizzonte), confrontata con lo spettro originale fuori atmosfera.
    2. Flusso integrato (totale e nel visibile) in funzione dell'angolo
       zenitale per il Sole.

Esecuzione:
    python simulazione_sole.py
"""

import numpy as np
import matplotlib.pyplot as plt
from tqdm import tqdm

from costanti import T_sole, n_samples, angoli, angoli_gradi
from atmosfera import simula_fotoni, flusso_integrato
import stile_grafici

# --- Simulazione distribuzioni spettrali ---
n_0, n_zenith = simula_fotoni(0,       T_sole, n_samples)
_, n_oriz     = simula_fotoni(np.pi/2, T_sole, n_samples)
print(f"Fotoni generati da Planck: {len(n_0)}")

fig, ax = plt.subplots(figsize=(15, 10))
bins = np.linspace(10, 2000, 120)
ax.axvspan(380, 750, alpha=0.2, color='yellow', label='Spettro visibile')
ax.axvline(380, color='purple',  linestyle='--', alpha=0.6)
ax.axvline(750, color='darkred', linestyle='--', alpha=0.6)
ax.hist(n_0      * 1e9, bins=bins, alpha=0.5, color='navy',   label='N_0 (spazio)')
ax.hist(n_zenith * 1e9, bins=bins, alpha=0.8, color='green',  label='Zenith')
ax.hist(n_oriz   * 1e9, bins=bins, alpha=0.8, color='orange', label='Orizzonte')
ax.set_xlabel('lambda [nm]')
ax.set_ylabel('Numero di fotoni')
ax.set_title(f'Sole (T = {T_sole} K) - distribuzione fotoni per lambda')
ax.legend()
plt.tight_layout()
plt.show()

# --- Flusso integrato vs angolo zenitale ---
flusso_tot_sole = []
flusso_vis_sole = []

for t in tqdm(angoli, desc='Sole'):
    flusso_tot_sole.append(flusso_integrato(t, T_sole, n_samples, 10e-9,  2000e-9))
    flusso_vis_sole.append(flusso_integrato(t, T_sole, n_samples, 380e-9, 750e-9))

flusso_tot_sole = np.array(flusso_tot_sole)
flusso_vis_sole = np.array(flusso_vis_sole)

fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))

ax1.plot(angoli_gradi, flusso_tot_sole, 'o-', color='goldenrod')
ax1.set_xlabel('Angolo zenitale theta [gradi]')
ax1.set_ylabel('N_finale / N_iniziale')
ax1.set_title('Spettro totale (10 - 2000 nm)')
ax1.set_ylim(0, 1.05)

ax2.plot(angoli_gradi, flusso_vis_sole, 'o-', color='goldenrod')
ax2.set_xlabel('Angolo zenitale theta [gradi]')
ax2.set_ylabel('N_finale / N_iniziale')
ax2.set_title('Spettro visibile (380 - 750 nm)')
ax2.set_ylim(0, 1.05)

fig.suptitle(f'Sole (T = {T_sole} K) - flusso integrato vs angolo zenitale')
plt.tight_layout()
plt.show()
